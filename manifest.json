{
  "manifest_version": 3,
  "name": "Dead Stats",
  "version": "1.0.0",
  "description": "Fetch info from the Deadlock API for quick hero lookups, comparisons, and item data.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [],
  "host_permissions": [
    "https://deadlock-api.com/*"
  ]
}
